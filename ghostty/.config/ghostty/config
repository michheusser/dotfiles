# Theme
#theme = Aizen Dark 
theme = Catppuccin Mocha
background = #11111b
#background = #1e1e29
#background = #181824

# Font
font-size = 13

# Window
window-padding-x = 8
window-padding-y = 8

# Shell
shell-integration = zsh
command = /usr/bin/zsh -l -i

# Keybindings - consistent with Linux
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard

